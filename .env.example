# Copy to .env on the EC2 box and fill in. Never commit the real .env.
DOMAIN=api.yourdomain.com
PUBLIC_BASE_URL=https://api.yourdomain.com   # photo URLs are built from this — must match DOMAIN

APP_ENV=production
MONGODB_URI=                                  # your Atlas connection string
MONGODB_DB=TwoTable
JWT_SECRET_KEY=                               # openssl rand -hex 32
EMBEDDING_PROVIDER=off                        # "local" needs ~2GB RAM (t3.small+)
DEV_OTP_CODE=12345                            # replace with real SMS before launch
MAPBOX_TOKEN=                                 # optional; postcodes.io fallback works without it
